# ─── Database (Railway PostgreSQL) ───────────────────────────────────────────
# Use the pgbouncer pooled URL for the app (port 6543)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/agriai?pgbouncer=true&connection_limit=1"
# Use the direct URL for Prisma migrations (port 5432)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/agriai"

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-to-another-long-random-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"
MOBILE_URL="exp://localhost:8081"

# ─── OpenWeatherMap ───────────────────────────────────────────────────────────
OPENWEATHER_API_KEY="your-openweathermap-api-key"

# ─── Africa's Talking ─────────────────────────────────────────────────────────
AT_API_KEY="your-africastalking-api-key"
AT_USERNAME="sandbox"
AT_SENDER_ID="AgriAI"
AT_USSD_CODE="*384*AgriAI#"

# ─── Google Maps ─────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
